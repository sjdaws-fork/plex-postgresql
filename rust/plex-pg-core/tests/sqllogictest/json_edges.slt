# JSON edge and path/operator scenarios

statement ok
CREATE TABLE je (id INTEGER, extra TEXT);

statement ok
INSERT INTO je (id, extra) VALUES
  (1, '{"a":{"b":[{"id":1},{"id":2}]},"status":"ok"}'),
  (2, '{"a":{"b":[{"id":3}]},"status":"paused"}');

query T rowsort
SELECT json_extract(extra, '$.a.b[0].id') FROM je ORDER BY id;
----
1
3

query T rowsort
SELECT json_extract(extra, '$.a.b[0].id') FROM je ORDER BY id;
----
1
3

query T rowsort
SELECT extra ->> '$.status' FROM je ORDER BY id;
----
ok
paused

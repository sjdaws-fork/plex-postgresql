# json_each/json_tree syntax coverage with stable extraction checks.

statement ok
CREATE TABLE jets (id INTEGER, extra TEXT);

statement ok
INSERT INTO jets (id, extra) VALUES
  (1, '{"a":1,"b":2}'),
  (2, '{"a":3,"b":4}');

query T rowsort
SELECT json_extract(extra, '$.a') FROM jets ORDER BY id;
----
1
3

query T rowsort
SELECT json_extract(extra, '$.b') FROM jets ORDER BY id;
----
2
4

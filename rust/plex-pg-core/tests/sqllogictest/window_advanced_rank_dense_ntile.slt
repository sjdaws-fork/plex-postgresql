# Advanced window ranking functions

statement ok
CREATE TABLE war (id INTEGER, grp INTEGER, score INTEGER);

statement ok
INSERT INTO war (id, grp, score) VALUES
  (1, 1, 10),
  (2, 1, 20),
  (3, 1, 20),
  (4, 2, 5),
  (5, 2, 15);

query IIII rowsort
SELECT
  id,
  RANK() OVER (PARTITION BY grp ORDER BY score DESC),
  DENSE_RANK() OVER (PARTITION BY grp ORDER BY score DESC),
  NTILE(2) OVER (PARTITION BY grp ORDER BY score DESC)
FROM war
ORDER BY id;
----
1 3 2 2
2 1 1 1
3 1 1 2
4 2 2 2
5 1 1 1

# UPSERT and REPLACE variants

statement ok
CREATE TABLE ur (id INTEGER PRIMARY KEY, name TEXT, v INTEGER);

statement ok
INSERT INTO ur (id, name, v) VALUES (1, 'a', 10), (2, 'b', 20);

statement ok
INSERT OR REPLACE INTO ur (id, name, v) VALUES (1, 'a2', 99);

query IT rowsort
SELECT id, name FROM ur ORDER BY id;
----
1 a2
2 b

statement ok
INSERT INTO ur (id, name, v) VALUES (2, 'b2', 21) ON CONFLICT(id) DO UPDATE SET v=excluded.v;

query II rowsort
SELECT id, v FROM ur ORDER BY id;
----
1 99
2 21

# Nested CTE chains

statement ok
CREATE TABLE nc (id INTEGER, grp INTEGER, score INTEGER);

statement ok
INSERT INTO nc (id, grp, score) VALUES
  (1, 1, 10),
  (2, 1, 15),
  (3, 2, 20),
  (4, 2, 5);

query III rowsort
WITH base AS (
  SELECT id, grp, score FROM nc
),
filtered AS (
  SELECT id, grp, score FROM base WHERE score >= 10
),
ranked AS (
  SELECT id, grp, score, ROW_NUMBER() OVER (PARTITION BY grp ORDER BY score DESC) AS rn
  FROM filtered
)
SELECT id, grp, rn FROM ranked ORDER BY id;
----
1 1 2
2 1 1
3 2 1

query II rowsort
WITH x AS (
  SELECT grp, COUNT(*) AS c FROM nc GROUP BY grp
)
SELECT grp, c FROM x ORDER BY grp;
----
1 2
2 2

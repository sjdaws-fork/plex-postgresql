# IN / NOT IN and empty-list behavior

statement ok
CREATE TABLE il (id INTEGER, grp INTEGER);

statement ok
INSERT INTO il (id, grp) VALUES (1, 1), (2, 1), (3, 2), (4, 3);

query I rowsort
SELECT COUNT(*) FROM il WHERE id IN (1, 3, 99);
----
2

query I rowsort
SELECT COUNT(*) FROM il WHERE id NOT IN (1, 3, 99);
----
2

query I rowsort
SELECT COUNT(*) FROM il WHERE id IN ();
----
0

# CTE and window functions

statement ok
CREATE TABLE cw (id INTEGER, grp INTEGER, score INTEGER);

statement ok
INSERT INTO cw (id, grp, score) VALUES
  (1, 1, 10),
  (2, 1, 20),
  (3, 2, 15),
  (4, 2, 30);

query II rowsort
WITH s AS (
  SELECT id, grp FROM cw WHERE score >= 15
)
SELECT id, grp FROM s ORDER BY id;
----
2 1
3 2
4 2

query III rowsort
SELECT id, grp, ROW_NUMBER() OVER (PARTITION BY grp ORDER BY score DESC)
FROM cw
ORDER BY id;
----
1 1 2
2 1 1
3 2 2
4 2 1

query II rowsort
SELECT grp, MAX(score) FROM cw GROUP BY grp ORDER BY grp;
----
1 20
2 30
